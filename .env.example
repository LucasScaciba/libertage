# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from your Supabase project settings: https://app.supabase.com
# Project Settings > API

# Public URL for your Supabase project (used in browser and server)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# Anonymous/public key for Supabase (used in browser and server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key for Supabase (server-side only, bypasses RLS)
# WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# =============================================================================
# STRIPE CONFIGURATION
# =============================================================================
# Get these from your Stripe dashboard: https://dashboard.stripe.com
# Developers > API keys

# Publishable key for Stripe (used in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Secret key for Stripe (server-side only)
# WARNING: Keep this secret! Never expose in client-side code
STRIPE_SECRET_KEY=your_stripe_secret_key

# Webhook signing secret for verifying Stripe webhook events
# Get this from: Developers > Webhooks > Add endpoint
# Webhook URL: https://your-domain.com/api/webhooks/stripe
# Events to listen for:
#   - checkout.session.completed
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.payment_failed
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret


# =============================================================================
# SMS PROVIDER CONFIGURATION (Twilio)
# =============================================================================
# Get these from your Twilio console: https://console.twilio.com
# Optional: Only needed if implementing phone verification

# Twilio Account SID
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio phone number (must be in E.164 format, e.g., +15551234567)
TWILIO_PHONE_NUMBER=your_twilio_phone_number


# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Public URL of your application (used for OAuth redirects and Stripe callbacks)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job secret for securing cron endpoints (optional but recommended)
# Generate a random string: openssl rand -base64 32
# Used to verify requests to /api/cron/* endpoints
CRON_SECRET=your_random_secret_string


# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Node environment (automatically set by hosting platforms)
# NODE_ENV=development

# Enable debug logging (optional)
# DEBUG=true
